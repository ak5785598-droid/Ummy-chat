rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match any file in the 'users' directory
    match /users/{userId}/{allPaths=**} {
      // Allow read access to anyone, authenticated or not.
      // This is common for public assets like profile pictures.
      allow read;
      
      // Allow write access (create, update, delete) only if the user is authenticated
      // AND their UID matches the {userId} in the path. This ensures users can only
      // modify their own files.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
