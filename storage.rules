rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is admin (supreme creator, developer, or has isAdmin custom property in Firestore users doc)
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1' ||
        request.auth.uid == '1338' ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
         'isAdmin' in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data &&
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // User profile images: Owner only write access
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // ROOM MUSIC & FILES - AUTHENTICATED USERS
    // NOTE: Enforced via Firestore rules (chatRooms/{roomId}/music)
    // ============================================
    match /rooms/{roomId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Chat room images: Authenticated users write access
    match /chatRooms/{chatRoomId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Moments / Social Graph images: Owner only write access
    match /moments/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin Managed Assets (Gifts, Boutique, Banners, RoomBanners)
    match /store/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gifts/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /roomBanners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Loot Management (Images & Videos)
    match /loot/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Emoji Management (Images & Animations)
    match /emojis/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Level Management (Badge Images)
    match /levels/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Medal Management (Medal Images)
    match /medals/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global fallback for supreme creator or standard read
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
