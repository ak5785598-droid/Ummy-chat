
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the Ummy app.",
      "properties": {
        "id": { "type": "string" },
        "specialId": { "type": "string", "description": "Unique 6-digit numeric ID." },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "diamonds": { "type": "number" },
            "totalSpent": { "type": "number" }
          }
        },
        "inventory": {
          "type": "object",
          "properties": {
            "activeFrame": { "type": "string" },
            "activeBubble": { "type": "string" },
            "ownedItems": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "stats": {
          "type": "object",
          "properties": {
            "followers": { "type": "number" },
            "fans": { "type": "number" }
          }
        }
      }
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "roomNumber": { "type": "string" },
        "ownerId": { "type": "string" },
        "category": { "type": "string" },
        "lockedSeats": { "type": "array", "items": { "type": "number" } },
        "stats": {
          "type": "object",
          "properties": {
            "totalGifts": { "type": "number" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User root identity."
        }
      },
      {
        "path": "/chatRooms/{roomId}",
        "definition": {
          "entityName": "ChatRoom",
          "schema": { "$ref": "#/backend/entities/ChatRoom" },
          "description": "Voice room metadata."
        }
      },
      {
        "path": "/chatRooms/{roomId}/participants/{userId}/signaling/{peerId}",
        "definition": {
          "entityName": "WebRTCSignal",
          "schema": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["offer", "answer", "candidate"] },
              "sdp": { "type": "string" },
              "candidate": { "type": "object" },
              "from": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          },
          "description": "Signaling messages for WebRTC handshakes."
        }
      }
    ]
  }
}
