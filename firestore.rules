rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Authorization Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isCreator() {
      return isSignedIn() && request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1';
    }

    function isNotBanned() {
      if (isCreator()) { return true; }
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) { return true; }
      let userData = get(userPath).data;
      return !('banStatus' in userData) || 
             userData.banStatus.isBanned == false || 
             (userData.banStatus.bannedUntil != null && userData.banStatus.bannedUntil < request.time);
    }

    // Root Users Collection: Strictly private to owner or creator
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isCreator();
      
      // Public Profile Subcollection: Open for tribal discovery
      match /profile/{profileId} {
        allow read: if isSignedIn() && isNotBanned();
        allow write: if isOwner(userId) || isCreator();
      }
      
      // Social Dimension subcollections
      match /profileVisitors/{visitorId} {
        allow read: if isSignedIn() && isNotBanned();
        allow write: if isSignedIn() && isNotBanned();
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isCreator();
        allow write: if isSignedIn() && isNotBanned();
      }

      match /topContributors/{contribId} {
        allow read: if isSignedIn() && isNotBanned();
        allow write: if isSignedIn() && isNotBanned();
      }
      
      match /diamondExchanges/{id} {
        allow read, write: if isOwner(userId);
      }
      
      match /followedRooms/{roomId} {
        allow read: if isSignedIn() && isNotBanned();
        allow write: if isOwner(userId);
      }
      
      match /completedTasks/{id} {
        allow read, write: if isOwner(userId) || isCreator();
      }

      match /collectedTasks/{id} {
        allow read, write: if isOwner(userId) || isCreator();
      }
    }

    // Required for collectionGroup queries
    match /{path=**}/profile/{profileId} {
      allow read: if isSignedIn() && isNotBanned();
    }

    // Private Message Frequencies
    match /privateChats/{chatId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participantIds || request.auth.uid in request.resource.data.participantIds);
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (chatId.contains(request.auth.uid));
      }
    }

    // Social Graph: Follower Hierarchy
    match /followers/{followId} {
      allow read: if isSignedIn() && isNotBanned();
      allow create: if isSignedIn() && isNotBanned() && (request.auth.uid == request.resource.data.followerId || isCreator());
      allow update: if isSignedIn() && isNotBanned() && (request.auth.uid == resource.data.followerId || isCreator());
      allow delete: if isSignedIn() && (followId.startsWith(request.auth.uid + "_") || isCreator());
    }

    // Global Grid collections
    match /chatRooms/{roomId} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isSignedIn() && isNotBanned();
      
      match /{allSub=**} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }

    match /games/{gameId} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isCreator();
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isCreator();
    }

    match /roomThemes/{themeId} {
      allow read: if true;
      allow write: if isCreator();
    }

    match /globalBroadcasts/{id} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isSignedIn() && isNotBanned();
    }

    match /globalGameWins/{id} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isSignedIn() && isNotBanned();
    }

    match /moments/{id} {
      allow read: if isSignedIn() && isNotBanned();
      allow create: if isSignedIn() && isNotBanned() && request.auth.uid == request.resource.data.userId;
      allow update: if isSignedIn() && isNotBanned() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSignedIn() && (request.auth.uid == request.resource.data.userId || isCreator());
    }
    
    match /globalTasks/{id} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isCreator();
    }
    
    match /transactions/{id} {
      allow read, write: if isCreator();
    }
  }
}