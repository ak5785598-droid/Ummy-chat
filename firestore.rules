/**
 * Standard Security Rules for Ummy
 * Optimized for real-time chat, participant tracking, and administrative actions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description   User Profile Rules
     */
    match /users/{userId}/profile/{profileId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    /**
     * @description   Top-level Users Rules (for Leaderboards)
     */
    match /users/{userId} {
      allow read, list: if isSignedIn();
    }

    /**
     * @description   Chat Room Rules
     */
    match /chatRooms/{chatRoomId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      // Allow updates if user is owner, moderator, or it's the default test room
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.moderatorIds || chatRoomId == 'mumbai-adda');
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || chatRoomId == 'mumbai-adda');
      
      /**
       * @description   Participant Rules (Presence & Seats)
       */
      match /participants/{participantId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      /**
       * @description   Message Rules (Real-time Chat)
       */
      match /messages/{chatMessageId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isSignedIn();
        allow update: if isSignedIn() && (resource.data.senderId == request.auth.uid);
      }
    }
    
    /**
     * @description   Friend Request Rules
     */
    match /friendRequests/{friendRequestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
    
    /**
     * @description   Virtual Gift Transaction Rules
     */
    match /userGifts/{userGiftId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
    }

    /**
     * @description   Global Gift Definition Rules
     */
    match /gifts/{giftId} {
      allow read, list: if isSignedIn();
    }
    
    /**
     * @description   Room Tag Rules
     */
    match /tags/{tagId} {
      allow read, list: if isSignedIn();
    }
  }
}