rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, identity-centric authorization model designed for a high-interaction 
     * voice/text chat platform. It prioritizes document ownership and explicit membership for access control.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    function isRoomParticipant(participantIds) {
      return isSignedIn() && (request.auth.uid in participantIds);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn(); // Allow discovery
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /profile/{profileId} {
        allow get: if isSignedIn();
        allow write: if isOwner(userId);
      }
      
      match /notifications/{notifId} {
        allow get, list, write: if isOwner(userId);
      }

      match /followingRooms/{roomId} {
        allow get, list, write: if isOwner(userId);
      }
      
      match /diamondExchanges/{exchangeId} {
        allow get, list, write: if isOwner(userId);
      }
    }

    match /chatRooms/{chatRoomId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn(); // Broaden for simple participantCount and settings sync
      allow delete: if isExistingOwner(resource.data.ownerId);

      match /participants/{participantId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == participantId || isRoomParticipant(get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.moderatorIds));
        
        match /signaling/{signalId} {
          allow get, list, write: if isSignedIn();
        }
      }

      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    match /roomThemes/{themeId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    match /moments/{momentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /appConfig/{configId} {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /adminLogs/{logId} {
      allow get, list, create: if isSignedIn();
    }
    
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}