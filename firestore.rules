rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Robust Admin Check: Verify if the user document has elevated tags.
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tags', []).hasAny(['Admin', 'Official']);
    }

    match /users/{userId} {
      // Users can read any summary for rankings/leaderboards
      allow read: if isSignedIn();
      // Users can create their own identity summary
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Allow updates if owner, admin, or ONLY updating stats/updatedAt (for gifting)
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'updatedAt']))
      );
      // Admins have global oversight
      allow delete: if isAdmin();
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == userId;
        // Allow updates if owner, admin, or ONLY updating stats/updatedAt (for gifting)
        allow update: if isSignedIn() && (
          request.auth.uid == userId || 
          isAdmin() || 
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'updatedAt']))
        );
        allow delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      // allow anyone to increment user/room counters during initialization
      allow write: if isSignedIn() && (configId == 'counters' || isAdmin());
    }
    
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /chatRooms/{chatRoomId} {
      function isRoomAdmin() {
        let roomData = get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data;
        return isAdmin() || roomData.ownerId == request.auth.uid || roomData.get('moderatorIds', []).hasAny([request.auth.uid]);
      }

      // Any signed in user can find and launch rooms
      allow read, list, create: if isSignedIn();
      
      // Allow regular users to update ONLY 'stats' and 'updatedAt' (required for sending gifts).
      allow update: if isSignedIn() && (
        isRoomAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'updatedAt']))
      );
      
      // Owners or Global Admins can terminate frequencies
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      match /participants/{participantId} {
        allow read, list, create: if isSignedIn();
        allow update: if isSignedIn() && (request.auth.uid == participantId || isRoomAdmin());
        allow delete: if isSignedIn() && (request.auth.uid == participantId || isRoomAdmin());
      }
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn();
        allow delete: if isSignedIn() && isRoomAdmin();
      }
    }

    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}