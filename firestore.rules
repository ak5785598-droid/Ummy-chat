rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // GLOBAL AUTHORIZATION HELPERS
    // ============================================
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1' || 
        request.auth.uid == '1338' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         'isAdmin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isNotBanned() {
      return isAdmin() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             !('banStatus' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.banStatus.isBanned == false || 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.banStatus.bannedUntil != null && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.banStatus.bannedUntil < request.time);
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
        match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() || (isOwner(userId) && isNotBanned());
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        // Allow owner to update their own profile
        allow update: if isOwner(userId) && isNotBanned();
        // Special permission for Gifting: Allow others to ONLY increment diamonds and received stats
        // This is a temporary measure because gifting is client-side.
        allow update: if isSignedIn() && isNotBanned() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wallet', 'stats', 'updatedAt']) &&
          !request.resource.data.wallet.diff(resource.data.wallet).affectedKeys().hasAny(['coins']);
        
        allow create: if isOwner(userId) && isNotBanned();
      }
      
      match /profileVisitors/{visitorId} {
        allow read, write: if isSignedIn() && isNotBanned();
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isSignedIn();
      }
      
      match /{allSub=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isNotBanned()) || isAdmin();
      }
    }

    match /{path=**}/profile/{profileId} {
      allow read: if true;
    }

    // ============================================
    // PRIVATE CHATS
    // ============================================
    match /privateChats/{chatId} {
      allow read, write: if isSignedIn() && isNotBanned() && (request.auth.uid in resource.data.participantIds || request.auth.uid in request.resource.data.participantIds);
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && isNotBanned() && (chatId.matches(".*" + request.auth.uid + ".*"));
      }
    }

    // ============================================
    // FOLLOWERS
    // ============================================
    match /followers/{followId} {
      allow read: if isSignedIn() && isNotBanned();
      allow create: if isSignedIn() && isNotBanned() && (request.auth.uid == request.resource.data.followerId || isAdmin());
      allow update: if isSignedIn() && isNotBanned() && (request.auth.uid == resource.data.followerId || isAdmin());
      allow delete: if isSignedIn() && (followId.matches("^" + request.auth.uid + "_.*") || isAdmin());
    }

    // ============================================
    // CHAT ROOMS - MAIN ROOM LOGIC
    // ============================================
    match /chatRooms/{roomId} {
      // Anyone can read room data
      allow read: if true;
      
      // Anyone can create rooms
      allow create: if isSignedIn() && isNotBanned();
      
      // MUSIC CONTROL: Only Owner or Moderator can update music state
      allow update: if isSignedIn() && isNotBanned() && (
        // Check if user is owner
        resource.data.ownerId == request.auth.uid ||
        // Check if user is moderator
        (resource.data.moderatorIds is list && request.auth.uid in resource.data.moderatorIds) ||
        // Allow anyone to update stats/rocket/participantCount/levelPoints (for gifting, joining, activity)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'rocket', 'participantCount', 'levelPoints', 'updatedAt']) ||
        // Admin override
        isAdmin()
      );
      
      // ============================================
      // ROOM SUBCOLLECTIONS
      // ============================================
      match /participants/{participantId} {
        allow read: if true;
        // Owner writes own participant doc; admin/moderator can manage others
        allow write: if isOwner(participantId) || isAdmin() ||
          (isSignedIn() && isNotBanned() && (
            get(/databases/$(database)/documents/chatRooms/$(roomId)).data.ownerId == request.auth.uid ||
            request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.moderatorIds
          ));
      }

      match /topSupporters/{supporterId} {
        allow read: if true;
        allow write: if isOwner(supporterId);
      }
      
      match /messages/{messageId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBanned();
        allow delete: if isAdmin() || (resource.data.senderId == request.auth.uid);
      }

      // YouTube sync state — host only
      match /youtube/{youtubeDoc} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isNotBanned() &&
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.ownerId == request.auth.uid;
      }

      // Live captions — user writes own captions
      match /captions/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isNotBanned() && uid == request.auth.uid;
      }

      // Screen share — any authenticated user
      match /features/{featureId} {
        allow read: if true;
        allow write: if isSignedIn() && isNotBanned();
      }

      // Bans — owner, admin, or moderator can manage
      match /bans/{bannedId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isNotBanned() && (
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.ownerId == request.auth.uid ||
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.moderatorIds
        );
      }

      match /{allSub=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ============================================
    // MUSIC LIBRARY SUBCOLLECTION
    // ============================================
    match /chatRooms/{roomId}/music/{musicId} {
      // Anyone can read music library
      allow read: if isSignedIn() && isNotBanned();
      
      // Anyone can upload music
      allow create: if isSignedIn() && isNotBanned();
      
      // Only uploader or room owner can delete
      allow delete: if isSignedIn() && isNotBanned() && (
        resource.data.uploadedBy == request.auth.uid ||
        get(/databases/$(database)/documents/chatRooms/$(roomId)).data.ownerId == request.auth.uid ||
        isAdmin()
      );
    }

    // ============================================
    // GAMES
    // ============================================
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned();
      allow update: if isSignedIn() && isNotBanned()
      // dice: 1-6 integer (prevents Ludo dice hack)
      && (!('dice' in request.resource.data) ||
          (request.resource.data.dice is number &&
           request.resource.data.dice >= 1 &&
           request.resource.data.dice <= 6))
      // turn: validated by client (players is array of objects, cannot use hasAny)
      // status: valid game states only
      && (!('status' in request.resource.data) ||
           request.resource.data.status in ['loading', 'mode_select', 'lobby',
                                             'playing', 'ended', 'betting',
                                             'spinning', 'result', 'started',
                                             'waiting', 'finished'])
      // winningNumber: must be a valid roulette number (0-36)
      && (!('winningNumber' in request.resource.data) ||
          (request.resource.data.winningNumber is number &&
           request.resource.data.winningNumber >= 0 &&
           request.resource.data.winningNumber <= 36) ||
          request.resource.data.winningNumber == null)
      // diceRolled: must be boolean
      && (!('diceRolled' in request.resource.data) ||
           request.resource.data.diceRolled is bool);
      allow delete: if isAdmin();
    }

    // ============================================
    // GAME ORACLE (admin forced results - admin only)
    // ============================================
    match /gameOracle/{gameId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================
    // GLOBAL BETS (game bet records)
    // ============================================
    match /globalBets/{betId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // GLOBAL GAME WINS (win records - own only)
    // ============================================
    match /globalGameWins/{winId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // GAME CARNIVAL (fruit party game state)
    // ============================================
    match /game_carnival/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isNotBanned();
    }

    // ============================================
    // CP PAIRS
    // ============================================
    match /cpPairs/{cpId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // FAMILIES
    // ============================================
    match /families/{familyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // CONFIG & THEMES
    // ============================================
    // ============================================
    // SYSTEM CONFIG & SILENT BANS
    // ============================================
    match /system_config/{docId} {
      allow read: if true; // Needed for the app to check ban status
      allow write: if isAdmin();
      
      match /silent_bans/devices/{deviceId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && configId == 'counters');
    }

    match /roomThemes/{themeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // LEVELS, MEDALS & CUSTOM EMOJIS (Admin Only)
    // ============================================
    match /levels/{levelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /medals/{medalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /customEmojis/{emojiId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // GLOBAL BROADCASTS
    // ============================================
    match /globalBroadcasts/{id} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isSignedIn() && isNotBanned();
    }

    // ============================================
    // GLOBAL GAME WINS
    // ============================================
    match /globalGameWins/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned();
      allow update, delete: if isAdmin();
    }

    // ============================================
    // MOMENTS
    // ============================================
    match /moments/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /{allSub=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    // ============================================
    // GLOBAL TASKS
    // ============================================
    match /globalTasks/{id} {
      allow read: if isSignedIn() && isNotBanned();
      allow write: if isAdmin();
    }
    
    // ============================================
    // TRANSACTIONS
    // ============================================
    match /transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /walletTransactions/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
    }

    // ============================================
    // COIN AUDIT LOGS
    // ============================================
    match /coin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Permanent records
    }

    // ================= ==========================
    // RECHARGE REQUESTS
    // ============================================
    match /rechargeRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isNotBanned();
      allow update, delete: if isAdmin();
    }

    // --- REPORTS ---
    match /reports/{id} {
      allow create: if isSignedIn();
      allow read, delete, update: if isAdmin();
    }

    // --- GIFTS ---
    match /giftList/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // VIP & BRANDING SETTINGS
    // ============================================
    match /settings/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // CUSTOMIZED GIFT REQUESTS
    // ============================================
    match /customizedGiftRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // BOUTIQUE HUB (Store Items)
    // ============================================
    match /storeItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // LEADERBOARD THEMES
    // ============================================
    match /leaderboardThemes/{themeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}