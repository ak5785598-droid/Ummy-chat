rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Allow listing the users collection for the leaderboard
    match /users {
      allow list: if isSignedIn();
      match /{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
        
        match /profile/{profileId} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId);
        }
      }
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }
    
    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /chatRooms {
      allow read, list, create, update: if isSignedIn();
      match /{chatRoomId} {
        allow read, list, create, update: if isSignedIn();
        allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        
        match /participants/{participantId} {
          allow read, list, create, update, delete: if isSignedIn();
        }
        match /messages/{messageId} {
          allow read, list, create, delete: if isSignedIn();
        }
      }
    }
  }
}