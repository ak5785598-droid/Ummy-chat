rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isCreator() {
      return isSignedIn() && request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1';
    }

    function isNotBanned() {
      if (isCreator()) return true;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      
      // If user doc doesn't exist, they can't be banned
      if (!exists(userPath)) return true;
      
      let userData = get(userPath).data;
      let banStatus = userData.get('banStatus', {});
      let isBanned = banStatus.get('isBanned', false);
      let bannedUntil = banStatus.get('bannedUntil', null);
      
      // If not banned, or ban has expired
      return isBanned == false || (bannedUntil != null && bannedUntil < request.time);
    }

    // Supreme Creator Protocol - Universal Sovereignty
    match /{allPaths=**} {
      allow read, write: if isCreator();
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let adminTags = [
        'Admin', 'Official', 'Super Admin', 'Admin Management', 
        'App Manager', 'Seller', 'Seller center', 'Coin Seller', 
        'Customer Service', 'Assistant', 'Official center'
      ];
      return isSignedIn() && isNotBanned() && (
        isCreator() || 
        (exists(userPath) && get(userPath).data.get('tags', []).hasAny(adminTags))
      );
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId);
      allow update: if isCreator() || (isOwner(userId) && isNotBanned()) || isAdmin();
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow get: if true;
        allow write: if (isOwner(userId) && isNotBanned()) || isAdmin() || isCreator();
      }
      
      match /notifications/{notifId} {
        allow get, list, write: if (isOwner(userId) && isNotBanned()) || isAdmin() || isCreator();
      }

      match /profileVisitors/{visitorId} {
        allow read: if isOwner(userId);
        allow write: if isSignedIn() && isNotBanned();
      }
    }

    match /followers/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid && isNotBanned();
      allow delete: if isSignedIn() && request.auth.uid != null && (resource.data.followerId == request.auth.uid);
    }

    match /chatRooms/{chatRoomId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isNotBanned();
      allow update: if isSignedIn() && isNotBanned();
      allow delete: if isAdmin();

      match /participants/{participantId} {
        allow get, list: if true;
        allow write: if isSignedIn() && isNotBanned();
      }
    }

    match /privateChats/{chatId} {
      allow create: if isSignedIn() && isNotBanned();
      allow get, list, update: if isSignedIn() && (isCreator() || resource.data.participantIds.hasAny([request.auth.uid]));

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }
  }
}