rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write access to all documents for authenticated users to ensure stability
    // and resolve permission errors during identity handshake and social graph sync.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Specifically allow read access to public configurations for all users
    match /appConfig/{configId} {
      allow read: if true;
    }
    match /roomThemes/{themeId} {
      allow read: if true;
    }
    
    // Explicitly handle the users collection and its subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      // Support for the social graph handshake
      match /{allSub=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}