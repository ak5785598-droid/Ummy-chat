{
  "appId": "ummyndiapvtltd.ummyvoice",
  "appName": "Ummy",
  "webDir": "public",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#140028"
    },
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com", "facebook.com", "phone"]
    }
  },
  "server": {
    "url": "https://ummy-chat.vercel.app",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "android": {
    "overrideUserAgent": "Mozilla/5.0 (Linux; Android 13; SM-S918B) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Mobile Safari/537.36"
  }
}